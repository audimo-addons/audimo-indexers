# Copy to .env and fill in.

# Public hostname Caddy will request a Let's Encrypt cert for and
# users will paste into Audimo. For a fresh DigitalOcean Droplet
# with public IP <your-public-ip>, this is "<your-public-ip-with-dashes>.sslip.io".
# (Replace dots with dashes.)
HOSTNAME=<your-public-ip-with-dashes>.sslip.io

# Long random shared secret. Users paste a URL containing this same
# value in the {config} segment; the addon rejects requests that
# don't carry it as X-Audimo-Addon-Key. Generate one with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
AUDIMO_ADDON_KEY=replace-me-with-a-long-random-string
